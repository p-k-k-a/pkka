{
  "openapi": "3.1.0",
  "info": {
    "title": "PKKA Backend API",
    "description": "REST API for the Alumni Club platform of the AGH Faculty of Computer Science.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local dev"
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Public events calendar"
    }
  ],
  "paths": {
    "/debug/token": {
      "get": {
        "tags": ["debug-token-controller"],
        "operationId": "debugToken",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": { "type": "object", "additionalProperties": {} }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/events": {
      "get": {
        "tags": ["Events"],
        "summary": "List of upcoming events (optional filtering by tags)",
        "operationId": "list",
        "parameters": [
          {
            "name": "tags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          },
          {
            "name": "pageable",
            "in": "query",
            "required": true,
            "schema": { "$ref": "#/components/schemas/Pageable" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PageEventListItemDto" }
              }
            }
          }
        }
      }
    },
    "/api/public/events/{id}": {
      "get": {
        "tags": ["Events"],
        "summary": "Details of a single event",
        "operationId": "getById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/EventDetailsDto" }
              }
            }
          }
        }
      }
    },
    "/api/announcements": {
      "get": {
        "summary": "Pobiera listę ogłoszeń",
        "operationId": "getAnnouncements",
        "responses": {
          "200": {
            "description": "Lista ogłoszeń pobrana pomyślnie",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Announcement" }
                }
              }
            }
          }
        }
      }
    },
    "/api/blog-posts/{slug}": {
      "get": {
        "summary": "Pobiera pojedynczy wpis bloga",
        "operationId": "getBlogPostBySlug",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "Przyjazny URL wpisu",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Wpis bloga pobrany pomyślnie",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlogPost" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pageable": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "format": "int32", "minimum": 0 },
          "size": { "type": "integer", "format": "int32", "minimum": 1 },
          "sort": { "type": "array", "items": { "type": "string" } }
        }
      },
      "EventListItemDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "startsAt": { "type": "string", "format": "date-time" },
          "type": { "type": "string", "enum": ["ONLINE", "IN_PERSON", "HYBRID"] },
          "location": { "type": "string" },
          "coverImageUrl": { "type": "string" },
          "seatLimit": { "type": "integer", "format": "int32" },
          "seatsTaken": { "type": "integer", "format": "int32" }
        }
      },
      "PageEventListItemDto": {
        "type": "object",
        "properties": {
          "totalElements": { "type": "integer", "format": "int64" },
          "totalPages": { "type": "integer", "format": "int32" },
          "size": { "type": "integer", "format": "int32" },
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EventListItemDto" }
          },
          "number": { "type": "integer", "format": "int32" },
          "first": { "type": "boolean" },
          "last": { "type": "boolean" },
          "numberOfElements": { "type": "integer", "format": "int32" },
          "pageable": { "$ref": "#/components/schemas/PageableObject" },
          "sort": { "$ref": "#/components/schemas/SortObject" },
          "empty": { "type": "boolean" }
        }
      },
      "PageableObject": {
        "type": "object",
        "properties": {
          "offset": { "type": "integer", "format": "int64" },
          "paged": { "type": "boolean" },
          "pageNumber": { "type": "integer", "format": "int32" },
          "pageSize": { "type": "integer", "format": "int32" },
          "sort": { "$ref": "#/components/schemas/SortObject" },
          "unpaged": { "type": "boolean" }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "empty": { "type": "boolean" },
          "sorted": { "type": "boolean" },
          "unsorted": { "type": "boolean" }
        }
      },
      "EventDetailsDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "fullDescription": { "type": "string" },
          "type": { "type": "string", "enum": ["ONLINE", "IN_PERSON", "HYBRID"] },
          "startsAt": { "type": "string", "format": "date-time" },
          "endsAt": { "type": "string", "format": "date-time" },
          "location": { "type": "string" },
          "seatLimit": { "type": "integer", "format": "int32" },
          "seatsTaken": { "type": "integer", "format": "int32" },
          "waitingListEnabled": { "type": "boolean" },
          "registrationClosesAt": { "type": "string", "format": "date-time" },
          "audience": { "type": "string", "enum": ["PUBLIC", "ALL_ALUMNI", "SPECIFIC_GROUP"] },
          "coverImageUrl": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        }
      },
      "Author": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string", "x-faker": "person.fullName" },
          "role": { "type": "string", "x-faker": "person.jobTitle" },
          "avatarUrl": { "type": "string", "x-faker": "image.avatar" }
        }
      },
      "Announcement": {
        "type": "object",
        "required": ["id", "title", "description", "content", "date", "time", "tag", "imageUrl", "slug", "author"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string", "x-faker": "lorem.sentence" },
          "content": { "type": "string", "x-faker": "lorem.paragraphs" },
          "date": { "type": "string", "description": "Data w formacie tekstowym (np. 10 maja 2026)" },
          "time": { "type": "string", "description": "Godzina publikacji (np. 14:30)" },
          "tag": { "type": "string", "description": "Kategoria (np. Wydarzenie, Warsztaty)" },
          "imageUrl": { "type": "string" },
          "slug": { "type": "string" },
          "author": { "$ref": "#/components/schemas/Author" }
        }
      },
      "BlogPost": {
        "type": "object",
        "required": ["id", "title", "description", "content", "publishedAt", "tag", "imageUrl", "slug", "author"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string", "x-faker": "lorem.sentence" },
          "description": { "type": "string", "x-faker": "lorem.sentence" },
          "content": { "type": "string", "x-faker": "lorem.paragraphs" },
          "publishedAt": { "type": "string", "format": "date-time" },
          "tag": { "type": "string" },
          "imageUrl": { "type": "string" },
          "slug": { "type": "string" },
          "author": { "$ref": "#/components/schemas/Author" }
        }
      }
    }
  }
}