    "generate": "turbo run generate"
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "^2.9.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "version": "1.0.0",
