{"openapi":"3.1.0","info":{"title":"PKKA Backend API","description":"REST API for the Alumni Club platform of the AGH Faculty of Computer Science.","version":"v1"},"servers":[{"url":"http://localhost:8080","description":"Local dev"}],"tags":[{"name":"Posts","description":"Public posts on the faculty blog"}],"paths":{"/debug/token":{"get":{"tags":["debug-token-controller"],"operationId":"debugToken","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"type":"object","additionalProperties":{}}}}}}}}},"/api/public/posts":{"get":{"tags":["Posts"],"summary":"List of published posts","description":"Available without authentication. Posts are ordered from newest to oldest.\nPagination parameters: page (default 0), size (default 10).\n","operationId":"listPosts","parameters":[{"name":"pageable","in":"query","required":true,"schema":{"$ref":"#/components/schemas/Pageable"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostSummaryResponse"}}}}}}},"/api/public/posts/{slug}":{"get":{"tags":["Posts"],"summary":"Single post by slug","description":"Available without authentication. Returns 404 if the post does not exist or is a draft.","operationId":"getPost","parameters":[{"name":"slug","in":"path","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"404":{"description":"Post does not exist or is not published","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}}}}}},"components":{"schemas":{"Pageable":{"type":"object","properties":{"page":{"type":"integer","format":"int32","minimum":0},"size":{"type":"integer","format":"int32","minimum":1},"sort":{"type":"array","items":{"type":"string"}}}},"PostSummaryResponse":{"type":"object","properties":{"id":{"type":"string","format":"uuid"},"slug":{"type":"string"},"title":{"type":"string"},"excerpt":{"type":"string"},"aut